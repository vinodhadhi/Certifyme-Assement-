{
  "info": {
    "name": "Qatar Foundation Admin Portal API",
    "description": "Complete API collection for the Qatar Foundation Admin Portal backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "US-1.1 Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Admin\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword\",\n  \"confirm_password\": \"securepassword\"\n}"
            }
          }
        },
        {
          "name": "US-1.2 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword\",\n  \"remember_me\": false\n}"
            }
          }
        },
        {
          "name": "US-1.2 Login (Remember Me)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securepassword\",\n  \"remember_me\": true\n}"
            }
          }
        },
        {
          "name": "US-1.3 Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        },
        {
          "name": "Validate Reset Token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/reset-password/PASTE_TOKEN_FROM_SERVER_LOGS_HERE"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/reset-password/PASTE_TOKEN_FROM_SERVER_LOGS_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newpassword123\",\n  \"confirm_password\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "US-2.1 Get All Opportunities",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/opportunities"
          }
        },
        {
          "name": "US-2.4 Get Single Opportunity",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/opportunities/1"
          }
        },
        {
          "name": "US-2.2 Create Opportunity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/opportunities",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Full Stack Developer Internship\",\n  \"duration\": \"3 months\",\n  \"start_date\": \"2025-09-01\",\n  \"description\": \"Join our team to build modern web applications using React and Flask.\",\n  \"skills\": \"React, Python, Flask, MySQL, REST APIs\",\n  \"category\": \"Technology\",\n  \"future_opportunities\": true,\n  \"max_applicants\": 10\n}"
            }
          }
        },
        {
          "name": "US-2.5 Update Opportunity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/opportunities/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Full Stack Developer Internship (Updated)\",\n  \"duration\": \"6 months\",\n  \"start_date\": \"2025-10-01\",\n  \"description\": \"Updated description for the internship role.\",\n  \"skills\": \"React, Python, Flask, MySQL, REST APIs, Docker\",\n  \"category\": \"Technology\",\n  \"future_opportunities\": false,\n  \"max_applicants\": 20\n}"
            }
          }
        },
        {
          "name": "US-2.6 Delete Opportunity",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/opportunities/1"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    }
  ]
}
